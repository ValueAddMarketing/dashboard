{
  "framework": null,
  "buildCommand": "mkdir -p dist/client-portal dist/george && cp index.html dashboard.html dist/ && cp client-portal/index.html dist/client-portal/index.html && cp george/index.html dist/george/index.html",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/portal", "destination": "/client-portal/index.html" },
    { "source": "/portal/:path*", "destination": "/client-portal/index.html" },
    { "source": "/george", "destination": "/george/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
