{
  "framework": null,
  "buildCommand": "mkdir -p dist/client-portal && cp index.html dashboard.html dist/ && cp client-portal/index.html dist/client-portal/index.html",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/fathom-sync-cron",
      "schedule": "0 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/portal", "destination": "/client-portal/index.html" },
    { "source": "/portal/:path*", "destination": "/client-portal/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
